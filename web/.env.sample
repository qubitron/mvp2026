# Azure AI Foundry project endpoint
# Format: https://<your-ai-services-account>.services.ai.azure.com/api/projects/<your-project-name>
FOUNDRY_PROJECT_ENDPOINT=https://mvp-demo-resource.services.ai.azure.com/api/projects/mvp-demo

# Name of an existing agent in your Foundry project (always uses the latest version)
AGENT_NAME=hotel-search-agent

# Server port (optional, defaults to 3000)
PORT=3000
